<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 使用情况访问权限（统计应用使用数据） -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- 悬浮窗权限 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- 前台服务 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- 开机自启动 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- 电池优化白名单（避免系统杀死无障碍服务，解决退出后权限失效） -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- 通知权限（Android 13+ 前台服务通知必需，否则 startForeground 会崩溃） -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 查询已安装应用（Android 11+ 包可见性）-->
    <!-- 不使用 QUERY_ALL_PACKAGES（Google Play 禁止），改用 <queries> 声明常见分心应用 -->
    <queries>
        <!-- 社交类 -->
        <package android:name="com.tencent.mm" />
        <package android:name="com.tencent.mobileqq" />
        <package android:name="com.ss.android.ugc.aweme" />
        <package android:name="com.smile.gifmaker" />
        <package android:name="com.xiaohongshu" />
        <package android:name="com.weico.international" />
        <package android:name="com.zhihu.android" />
        <package android:name="com.baidu.tieba" />
        <!-- 视频/娱乐类 -->
        <package android:name="com.tencent.qqlive" />
        <package android:name="tv.danmaku.bili" />
        <package android:name="com.youku.phone" />
        <package android:name="com.qiyi.video" />
        <!-- 购物类 -->
        <package android:name="com.taobao.taobao" />
        <package android:name="com.tmall.wireless" />
        <package android:name="com.jingdong.app.mall" />
        <package android:name="com.xunmeng.pinduoduo" />
        <!-- 游戏类 -->
        <package android:name="com.tencent.tmgp.sgame" />
        <!-- 通用 intent 查询：支持用户手动添加任意应用 -->
        <intent>
            <action android:name="android.intent.action.MAIN" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
    </queries>

    <application
        android:name=".FocusGuardApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/Theme.FocusGuard"
        tools:targetApi="35">

        <!-- Android 14+ specialUse 前台服务子类型声明 -->
        <property
            android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
            android:value="focus_guard_protection" />

        <!-- 主界面 -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.FocusGuard.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 反思拦截页面（FocusCat） -->
        <activity
            android:name=".ReflectionActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleInstance"
            android:noHistory="false"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode|fontScale|density|smallestScreenSize"
            android:theme="@style/Theme.FocusGuard.Quiz" />

        <!-- 确认/食物奖励页面 -->
        <activity
            android:name=".ConfirmActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleInstance"
            android:noHistory="false"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode|fontScale|density|smallestScreenSize"
            android:theme="@style/Theme.FocusGuard.Quiz" />

        <!-- 无障碍服务 - 监听应用启动 -->
        <service
            android:name=".accessibility.AppMonitorService"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- 前台保活服务 -->
        <service
            android:name=".service.FocusGuardService"
            android:foregroundServiceType="specialUse"
            android:exported="false" />

        <!-- 开机自启动 / 应用更新后自恢复接收器 -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- 修复 C：AlarmManager 第三方守护者接收器 -->
        <!-- 由 setInexactRepeating 定时触发，独立于 app 进程，确保前台服务被杀后能被拉起 -->
        <receiver
            android:name=".service.ServiceRestartReceiver"
            android:exported="false" />

        <!-- 文件提供者 - 用于数据导出分享 -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
